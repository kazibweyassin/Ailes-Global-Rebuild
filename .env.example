# Database
DATABASE_URL="postgresql://username:password@localhost:5432/ailes_global"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Configuration (optional - for AI Copilot)
# Get free API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# Pesapal Payment (for Uganda/East Africa - Mobile Money, Cards, Bank Transfer)
# Sign up at https://www.pesapal.com/dashboard
# Documentation: https://developer.pesapal.com/how-to-integrate/api-30-json/api-reference
PESAPAL_CONSUMER_KEY="your-pesapal-consumer-key"
PESAPAL_CONSUMER_SECRET="your-pesapal-consumer-secret"
PESAPAL_ENV="sandbox"  # Change to "live" for production

# Node Environment
NODE_ENV="development"
